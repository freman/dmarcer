# dmarcer configuration
# Copy to .env and fill in your values.
# All settings can also be set as environment variables (env vars take precedence over .env).
# Duration values accept Go duration strings: 30s, 5m, 1h30m, 24h, etc.

# ── General ───────────────────────────────────────────────────────────────────
#DMARCER_HTTP_ADDR=:8080             # HTTP listen address
#DMARCER_DB_PATH=./dmarcer.db        # SQLite database path
#DMARCER_BASE_URL=                   # Public base URL (e.g. https://dmarcer.example.com) - used for links
#DMARCER_LOG_LEVEL=info              # debug, info, warn, error
#DMARCER_OFFLINE=false               # Disable all outbound network calls (DNS lookups, GeoIP downloads)
#DMARCER_API_KEY=                    # Set to password-protect the dashboard and API

# ── Report storage ────────────────────────────────────────────────────────────
#DMARCER_SAVE_AGGREGATE=true         # Save DMARC aggregate (rua) reports to SQLite
#DMARCER_SAVE_FORENSIC=true          # Save DMARC forensic (ruf) reports to SQLite
#DMARCER_SAVE_SMTP_TLS=true          # Save SMTP TLS (RFC 8460) reports to SQLite
#DMARCER_STRIP_ATTACHMENT_PAYLOADS=false  # Remove raw attachment bytes from forensic reports before saving
#DMARCER_NORMALIZE_TIMESPAN=24h      # Snap aggregate report begin/end times to multiples of this duration

# ── Upload ────────────────────────────────────────────────────────────────────
#DMARCER_UPLOAD_ENABLED=true         # Enable manual report upload via the web UI
#DMARCER_UPLOAD_MAX_SIZE_MB=25       # Maximum upload size in megabytes

# ── Sender map ────────────────────────────────────────────────────────────────
#DMARCER_SENDER_MAP_PATH=            # Path to a custom sender map CSV (base_reverse_dns,name,type)
                                     # Overrides the built-in map when set.

# ── GeoIP ─────────────────────────────────────────────────────────────────────
# Option A: point at an existing MMDB file (DB-IP or MaxMind format).
#   Free DB-IP Country Lite: https://db-ip.com/db/download/ip-to-country-lite
#DMARCER_GEOIP_DB_PATH=/path/to/dbip-country-lite.mmdb

# Option B: auto-download GeoLite2-Country from MaxMind (free account required).
#   Sign up at https://www.maxmind.com/en/geolite2/signup
#   If GEOIP_DB_PATH is unset with auto-update enabled, defaults to ./geoip.mmdb
#DMARCER_GEOIP_ACCOUNT_ID=123456
#DMARCER_GEOIP_LICENSE_KEY=your_license_key_here
#DMARCER_GEOIP_UPDATE_INTERVAL=24h   # How often to re-download the GeoIP database

# ── DNS ───────────────────────────────────────────────────────────────────────
#DMARCER_NAMESERVERS=1.1.1.1,1.0.0.1 # Comma-separated list of DNS resolvers for PTR lookups
#DMARCER_DNS_TIMEOUT=2s              # Timeout per DNS query
#DMARCER_DNS_CACHE_TTL=4h            # How long to cache PTR lookup results
#DMARCER_DNS_CACHE_MAX=10000         # Maximum number of cached PTR entries

# ── IMAP ──────────────────────────────────────────────────────────────────────
# IMAP ingestion is enabled automatically when DMARCER_IMAP_HOST is set.
DMARCER_IMAP_HOST=mail.example.com
DMARCER_IMAP_USER=dmarc@example.com
DMARCER_IMAP_PASSWORD=your-password-here
#DMARCER_IMAP_PORT=993
#DMARCER_IMAP_TLS=true               # Use TLS (IMAPS); set false for STARTTLS or plain
#DMARCER_IMAP_TLS_SKIP_VERIFY=false  # Skip TLS certificate verification (insecure)
#DMARCER_IMAP_INBOX=INBOX            # Mailbox to poll for new reports
#DMARCER_IMAP_ARCHIVE_FOLDER=Archive # Folder to move processed messages into (sub-folders created per type)
#DMARCER_IMAP_DELETE=false           # Delete processed messages instead of archiving
#DMARCER_IMAP_WATCH=false            # true = use IMAP IDLE for real-time delivery; false = poll
#DMARCER_IMAP_POLL_INTERVAL=5m       # How often to poll when IMAP_WATCH=false
#DMARCER_IMAP_BATCH_SIZE=10          # Number of messages to fetch per poll cycle
#DMARCER_IMAP_TIMEOUT=28m            # Timeout for a single IMAP session (should be < server idle timeout)
#DMARCER_IMAP_MAX_RETRIES=4          # Number of reconnect attempts on IMAP failure

# ── Elasticsearch (optional) ──────────────────────────────────────────────────
# Elasticsearch output is enabled automatically when DMARCER_ES_URL is set,
# or explicitly via DMARCER_ES_ENABLED=true.
#DMARCER_ES_ENABLED=false
#DMARCER_ES_URL=http://elasticsearch:9200   # Comma-separated list of Elasticsearch node URLs
#DMARCER_ES_USER=
#DMARCER_ES_PASSWORD=
#DMARCER_ES_API_KEY=                 # Alternative to user/password (base64 encoded id:key)
#DMARCER_ES_TLS_SKIP_VERIFY=false    # Skip TLS certificate verification (insecure)
#DMARCER_ES_CA_CERT_PATH=            # Path to custom CA certificate for TLS verification
#DMARCER_ES_INDEX_PREFIX=dmarcer_    # Prefix for all Elasticsearch index names
#DMARCER_ES_INDEX_SUFFIX=            # Optional suffix appended to index names
#DMARCER_ES_MONTHLY_INDEXES=false    # Append YYYY-MM to index names for monthly rotation
#DMARCER_ES_TIMEOUT=60s              # HTTP request timeout for Elasticsearch
#DMARCER_ES_SHARDS=1                 # Number of primary shards for auto-created indexes
#DMARCER_ES_REPLICAS=0               # Number of replicas for auto-created indexes
#DMARCER_ES_FAIL_ON_ERROR=false      # Halt ingest pipeline on Elasticsearch write errors

# ── OpenObserve (optional) ────────────────────────────────────────────────────
# OpenObserve output is enabled automatically when DMARCER_OO_URL is set,
# or explicitly via DMARCER_OO_ENABLED=true.
#DMARCER_OO_ENABLED=false
#DMARCER_OO_URL=http://openobserve:5080
#DMARCER_OO_ORG=default              # OpenObserve organisation
#DMARCER_OO_USER=root@example.com
#DMARCER_OO_PASSWORD=
#DMARCER_OO_TOKEN=                   # Alternative to user/password (Bearer token)
#DMARCER_OO_TLS_SKIP_VERIFY=false    # Skip TLS certificate verification (insecure)
#DMARCER_OO_STREAM_AGGREGATE=dmarcer_aggregate  # Stream name for aggregate reports
#DMARCER_OO_STREAM_FORENSIC=dmarcer_forensic    # Stream name for forensic reports
#DMARCER_OO_STREAM_SMTP_TLS=dmarcer_smtp_tls    # Stream name for SMTP TLS reports
#DMARCER_OO_BATCH_SIZE=100           # Number of records per bulk ingest request
#DMARCER_OO_TIMEOUT=60s              # HTTP request timeout for OpenObserve
#DMARCER_OO_FAIL_ON_ERROR=false      # Halt ingest pipeline on OpenObserve write errors
